{
  "name": "odoox",
  "version": "0.1.0",
  "description": "Type-safe JSON-RPC and XML-RPC client for Odoo — works with Node.js, Next.js, and React",
  "author": "whybe <vvhybe@hotmail.com>",
  "license": "MIT",
  "keywords": [
    "odoo",
    "rpc",
    "api",
    "jsonrpc",
    "xmlrpc",
    "erp",
    "connect",
    "sdk",
    "typescript",
    "nextjs",
    "react",
    "nodejs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/odoo.errors.js",
      "types": "./dist/errors/odoo.errors.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint-staged": "lint-staged",
    "prepublishOnly": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build",
    "release": "npm run prepublishOnly && npm publish",
    "commit": "cz",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vvhybe/odoox.git"
  },
  "bugs": {
    "url": "https://github.com/vvhybe/odoox/issues"
  },
  "homepage": "https://github.com/vvhybe/odoox#readme",
  "dependencies": {
    "jsdom": "^29.0.1"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": {
      "typescript": "6.0.2"
    },
    "@typescript-eslint/parser": {
      "typescript": "6.0.2"
    },
    "@typescript-eslint/type-utils": {
      "typescript": "6.0.2"
    },
    "@typescript-eslint/utils": {
      "typescript": "6.0.2"
    },
    "typescript-eslint": {
      "typescript": "6.0.2"
    },
    "lodash": "^4.17.23",
    "tmp": "^0.2.4",
    "minimist": "^1.2.6",
    "minimatch": "^10.2.4"
  }
}
